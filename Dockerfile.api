FROM node:20-alpine
RUN npm install -g pnpm
WORKDIR /app
# Copy workspace root files
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
# Copy all packages needed for API build
COPY packages/ packages/
COPY apps/ apps/
# Install all deps (including devDeps for tsc, prisma CLI)
RUN pnpm install --frozen-lockfile
# Build shared package first (other packages depend on its dist/)
RUN pnpm --filter @makenashville/shared build
# Generate Prisma client, then compile the db package to dist/
RUN pnpm db:generate
RUN pnpm --filter @makenashville/db build
# Build API TypeScript
RUN pnpm --filter @makenashville/api build
# Entrypoint handles DB push + SESSION_SECRET generation
COPY docker/api-entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh
EXPOSE 4000
ENTRYPOINT ["/entrypoint.sh"]
