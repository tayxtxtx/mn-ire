{
  "name": "makenashville-booking-system",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "db:generate": "pnpm -F @makenashville/db generate",
    "db:migrate": "pnpm -F @makenashville/db migrate",
    "db:push": "pnpm -F @makenashville/db push",
    "db:migrate:prod": "pnpm -F @makenashville/db migrate:deploy",
    "db:seed": "pnpm -F @makenashville/db seed",
    "db:studio": "pnpm -F @makenashville/db studio"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "prisma": "5.22.0",
    "turbo": "^2.1.3",
    "typescript": "^5.5.4"
  }
}
