# =========================================================================
# MN-IRE — Environment Variables
# Copy to .env and fill in. NEVER commit .env.
# =========================================================================

NODE_ENV=development

# ----- Postgres -----
# Used by Prisma (packages/db) and the API (apps/api)
DATABASE_URL=postgresql://mnire:mnire@localhost:5432/mnire?schema=public

# ----- Redis -----
# Sessions, rate-limit buckets, GCal sync locks, no-show timer scheduling.
REDIS_URL=redis://localhost:6379

# ----- Identity Provider -----
# Set to "authentik" (default) or "slack".
# Only fill in the section that matches your choice.
AUTH_PROVIDER=authentik

# --- Option A: Authentik OIDC (AUTH_PROVIDER=authentik) ---
# Custom scopes on the Authentik client must include the certification list,
# e.g. `woodshop_basic metal_lathe cnc_advanced laser_certified`.
AUTHENTIK_ISSUER_URL=https://auth.makenashville.org/application/o/mn-ire/
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
AUTHENTIK_REDIRECT_URI=http://localhost:5173/auth/callback
# Comma-separated list of cert scopes beyond `openid profile email`.
AUTHENTIK_CERT_SCOPES=woodshop_basic,woodshop_advanced,metal_lathe,metal_mill,cnc_basic,cnc_advanced,laser_certified,3dprint_basic,welding_mig,welding_tig,electronics_basic

# --- Option B: Sign in with Slack (AUTH_PROVIDER=slack) ---
# Create a Slack app, enable "Sign in with Slack" (OpenID Connect),
# add scopes: openid profile email. Certifications are managed in the DB.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:4000/auth/callback

# ----- Slack Bot (optional, works with either AUTH_PROVIDER) -----
# Socket Mode requires app-level token (xapp-) plus a bot token (xoxb-).
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=
# Channel routing for "Guild Alerts" — comma-separated key=channel pairs.
SLACK_GUILD_CHANNELS=woodshop=#woodshop-captains,metalshop=#metal-captains,cnc=#cnc-captains,laser=#laser-captains,electronics=#electronics-captains

# ----- Google Calendar -----
# Service account or OAuth2 user token. We use a single service identity for
# the facility calendars; per-shop calendars are configured in the DB.
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=
# UID prefix MUST match @mn-ire/shared#UID_PREFIX. Used to short-circuit
# bidirectional sync loops between MN-IRE and GCal.
GOOGLE_CALENDAR_UID_PREFIX=mn-booking-

# ----- API -----
API_PORT=4000
API_PUBLIC_URL=http://localhost:4000
WEB_PUBLIC_URL=http://localhost:5173
KIOSK_PUBLIC_URL=http://localhost:5174
SESSION_SECRET=change-me-in-prod

# ----- Admin -----
# Comma-separated list of email addresses that get isAdmin=true on first login.
# After the initial login you can manage admin status via PATCH /api/admin/users/:id.
ADMIN_EMAILS=

# ----- Booking policy (overrideable per-resource in DB) -----
DEFAULT_BOOKING_WINDOW_DAYS=7
DEFAULT_NO_SHOW_GRACE_MINUTES=15
HIGH_DEMAND_COOLDOWN_HOURS=4
